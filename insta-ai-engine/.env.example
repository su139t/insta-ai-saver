# Copy this file to .env and fill in your real values (.env is gitignored).
#   cp .env.example .env

# Whisper model size: tiny | base | small | medium | large-v3
WHISPER_MODEL=medium

# Cloudinary (for permanent thumbnails). Get this from your Cloudinary
# dashboard. If unset, thumbnails fall back to the (expiring) Instagram CDN URL.
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
